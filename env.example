# =============================================================================
# NeuralOps — Jitsi Topic Segmentation & Recap
# .env.example — SAFE TO COMMIT. Copy to .env and fill in real values.
#
#   cp .env.example .env
#   nano .env          # set FLOATING_IP and all passwords
#   docker compose up -d
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# CHAMELEON VM
# ─────────────────────────────────────────────────────────────────────────────
FLOATING_IP=YOUR_CHAMELEON_FLOATING_IP


# ─────────────────────────────────────────────────────────────────────────────
# POSTGRES
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_USER=recap
POSTGRES_PASSWORD=CHANGE_ME


# ─────────────────────────────────────────────────────────────────────────────
# MINIO  (MLflow artifact store — model weights only, NOT training data)
# ─────────────────────────────────────────────────────────────────────────────
MINIO_USER=minioadmin
MINIO_PASSWORD=CHANGE_ME


# ─────────────────────────────────────────────────────────────────────────────
# CHAMELEON OBJECT STORAGE  (training datasets via rclone)
# ─────────────────────────────────────────────────────────────────────────────
RCLONE_REMOTE=chi_tacc
OBJSTORE_BUCKET=objstore-proj07


# ─────────────────────────────────────────────────────────────────────────────
# JITSI
# ─────────────────────────────────────────────────────────────────────────────
JITSI_PORT=8443
JVB_PORT=10000


# ─────────────────────────────────────────────────────────────────────────────
# RETRAINING
# ─────────────────────────────────────────────────────────────────────────────
RETRAIN_THRESHOLD=5          # 5 for demo, 500 for production


# ─────────────────────────────────────────────────────────────────────────────
# MONITORING
# ─────────────────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
