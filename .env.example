# .env.example — NeuralOps Full System
# Copy to .env and fill in all REQUIRED values before running: bash setup.sh
# DO NOT commit .env — this file is safe to commit.

# =============================================================================
# CHAMELEON VM                                                       REQUIRED
# =============================================================================

FLOATING_IP=<your-chameleon-floating-ip>

# =============================================================================
# POSTGRES                                                           REQUIRED
# =============================================================================

POSTGRES_USER=proj07_user
POSTGRES_PASSWORD=<choose-a-strong-password>
POSTGRES_DB=proj07_sql_db

# External DSN for scripts/tools running outside Docker
DATABASE_URL=postgresql://proj07_user:<password>@<FLOATING_IP>:5432/proj07_sql_db

# =============================================================================
# MINIO  (MLflow artifact store)                                     REQUIRED
# =============================================================================

MINIO_USER=minioadmin
MINIO_PASSWORD=<choose-a-strong-password>

# =============================================================================
# CHAMELEON OBJECT STORAGE  (training data via rclone)               REQUIRED
# Configure on host first:
#   rclone config  →  name: chi_tacc, type: s3, provider: Ceph
#                     endpoint: https://chi.tacc.chameleoncloud.org:7480
# =============================================================================

RCLONE_REMOTE=chi_tacc
OBJSTORE_BUCKET=objstore-proj07
BUCKET=objstore-proj07

# =============================================================================
# MLFLOW + CHI@TACC S3 CREDENTIALS                                   REQUIRED
# From CHI@TACC openrc.sh (Application Credentials)
# =============================================================================

AWS_ACCESS_KEY_ID=<from-openrc.sh>
AWS_SECRET_ACCESS_KEY=<from-openrc.sh>
MLFLOW_S3_ENDPOINT_URL=https://chi.tacc.chameleoncloud.org:7480
MLFLOW_TRACKING_URI=http://<FLOATING_IP>:5000
BUCKET_NAME=proj07-mlflow-artifacts

# =============================================================================
# DATA PIPELINE                                                       REQUIRED
# =============================================================================

# Auth token checked by jitsi_transcript_receiver (must match Jitsi stack)
INGEST_TOKEN=<generate: openssl rand -hex 32>

# Host port for the ingest receiver (default 9099; must not conflict with MinIO)
INGEST_PORT=9099

# Serving API URLs used by stage1/stage2 forward workers (internal Docker names)
STAGE1_FORWARD_URL=http://serving-api:8000/segment
STAGE2_FORWARD_URL=http://serving-api:8000/summarize

# =============================================================================
# PORTS  (change only if defaults conflict with other services)
# =============================================================================

JITSI_PORT=8443
JVB_PORT=10000
ADMINER_PORT=5050

# =============================================================================
# RETRAINING
# =============================================================================

# Feedback events before retrain triggers. 5 for demo; 500 for production.
RETRAIN_THRESHOLD=5

# =============================================================================
# MONITORING
# =============================================================================

GRAFANA_PASSWORD=<choose-a-password>

# =============================================================================
# JITSI STACK  (only needed if running: DEPLOY_JITSI=true bash setup.sh)
# =============================================================================

# Public HTTPS URL — must match FLOATING_IP and JITSI_PORT
PUBLIC_URL=https://<FLOATING_IP>:8443

# PostgreSQL DSN for the meeting-portal (uses FLOATING_IP — separate network)
MEETING_PORTAL_DATABASE_URL=postgresql://proj07_user:<password>@<FLOATING_IP>:5432/proj07_sql_db

# Where transcript-uploader POSTs Jitsi transcripts (must match INGEST_PORT)
JITSI_TRANSCRIPT_INGEST_URL=http://<FLOATING_IP>:9099/ingest/jitsi-transcript

# Leave blank — install-jitsi-vm.sh auto-generates these.
# Copy values back here from /mnt/block/jitsi/.env after first install.
JWT_APP_SECRET=
MEETING_PORTAL_SESSION_SECRET=
JITSI_HOST_EXTERNAL_KEY=

# SIP credentials for Jigasi (replace if using real PSTN/SIP provider)
JIGASI_SIP_URI=test@sip2sip.info
JIGASI_SIP_PASSWORD=passw0rd
JIGASI_SIP_SERVER=sip2sip.info
JIGASI_SIP_PORT=5060
JIGASI_SIP_TRANSPORT=UDP
