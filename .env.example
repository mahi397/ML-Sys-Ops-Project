# .env.example — NeuralOps root configuration
# Copy to .env and fill in the values you actually use.
#
# This file is intentionally short:
# - data runtime, Jitsi, and the meeting portal share the same Postgres DB
# - Jitsi/data live behind the same FLOATING_IP
# - setup.sh + install-jitsi-vm.sh derive the Jitsi URLs and DB links for you
# - advanced worker/Jitsi tuning already has defaults in code/compose

# -----------------------------------------------------------------------------
# Core host / topology
# -----------------------------------------------------------------------------

# Public IP of this VM. For a split deployment, this is the data + Jitsi VM IP.
FLOATING_IP=replace_with_chameleon_floating_ip

# full: local data + serving + training + monitoring + MLflow
# data-jitsi: local data + Postgres + Jitsi, but forwards inference to serving VM
SETUP_MODE=full

# If serving is on another VM, point the data pipeline at that host.
STAGE1_FORWARD_URL=http://serving-api:8000/segment
STAGE2_FORWARD_URL=http://serving-api:8000/summarize

# Optional per-group overrides for custom VM roles.
# START_DATA_SERVICES=true
# START_SERVING_SERVICES=false
# START_TRAINING_SERVICES=false
# START_MONITORING_SERVICES=false
# START_MLFLOW_SERVICES=false
# DOWNLOAD_ML_MODELS=false

# -----------------------------------------------------------------------------
# Shared Postgres (same DB for runtime + meeting portal)
# -----------------------------------------------------------------------------

POSTGRES_PASSWORD=replace_with_strong_password

# Optional overrides if you are not using the repo defaults.
# POSTGRES_USER=proj07_user
# POSTGRES_DB=proj07_sql_db
# POSTGRES_DATA_DIR=/mnt/block/postgres-data

# -----------------------------------------------------------------------------
# Object storage / MLflow
# -----------------------------------------------------------------------------

RCLONE_REMOTE=rclone_s3
OBJECT_BUCKET=objstore-proj07

# Main data-pipeline bucket. MLflow artifacts can use a different bucket.
# Full-mode local MLflow defaults clients to http://mlflow:5000 inside Docker.
# Set this only when your MLflow server is on a different host.
MLFLOW_TRACKING_URI=

# Full-mode only: local MLflow + MinIO services.
MINIO_PASSWORD=replace_with_strong_password
BUCKET_NAME=proj07-mlflow-artifacts
GRAFANA_PASSWORD=replace_with_password

# setup.sh fills these from the configured rclone remote when left blank.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
MLFLOW_S3_ENDPOINT_URL=

# -----------------------------------------------------------------------------
# Optional operational overrides
# -----------------------------------------------------------------------------

INGEST_PORT=9099
JITSI_TRANSCRIPT_TIMEZONE=UTC
RETRAIN_THRESHOLD=5

# Same-host Jitsi/data deployments should keep this at host.docker.internal.
# For a split deployment, override this or set the full URLs below.
# JITSI_HOST_ACCESS_HOST=host.docker.internal
# JITSI_TRANSCRIPT_INGEST_URL=http://<data-vm-ip>:9099/ingest/jitsi-transcript
# MEETING_PORTAL_DATABASE_URL=postgresql://proj07_user:<password>@<data-vm-ip>:5432/proj07_sql_db

# Jitsi-generated/shared secrets. Leave blank; the installer writes them back.
INGEST_TOKEN=
JWT_APP_SECRET=
MEETING_PORTAL_SESSION_SECRET=
JITSI_HOST_EXTERNAL_KEY=
