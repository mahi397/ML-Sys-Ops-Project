# .env.example — NeuralOps Full System
# Copy to .env and fill in all REQUIRED values before running: bash setup.sh
# DO NOT commit .env — this file is safe to commit.

# =============================================================================
# CHAMELEON VM                                                       REQUIRED
# =============================================================================

FLOATING_IP=replace_with_chameleon_floating_ip

# =============================================================================
# POSTGRES                                                           REQUIRED
# =============================================================================

POSTGRES_USER=proj07_user
POSTGRES_PASSWORD=replace_with_strong_password
POSTGRES_DB=proj07_sql_db

# External DSN for scripts/tools running outside Docker
DATABASE_URL=postgresql://proj07_user:replace_with_strong_password@replace_with_chameleon_floating_ip:5432/proj07_sql_db

# =============================================================================
# MINIO  (MLflow artifact store)                                     REQUIRED
# =============================================================================

MINIO_USER=minioadmin
MINIO_PASSWORD=replace_with_strong_password

# =============================================================================
# CHAMELEON OBJECT STORAGE  (training data via rclone)               REQUIRED
# Configure on host first:
#   rclone config  →  name: chi_tacc, type: s3, provider: Ceph
#                     endpoint: https://chi.tacc.chameleoncloud.org:7480
# =============================================================================

RCLONE_REMOTE=chi_tacc
OBJSTORE_BUCKET=objstore-proj07
BUCKET=objstore-proj07

# =============================================================================
# MLFLOW + CHI@TACC S3 CREDENTIALS                                   REQUIRED
# From CHI@TACC openrc.sh (Application Credentials)
# =============================================================================

AWS_ACCESS_KEY_ID=replace_with_openrc_access_key
AWS_SECRET_ACCESS_KEY=replace_with_openrc_secret_key
MLFLOW_S3_ENDPOINT_URL=https://chi.tacc.chameleoncloud.org:7480
MLFLOW_TRACKING_URI=http://replace_with_chameleon_floating_ip:5000
BUCKET_NAME=proj07-mlflow-artifacts

# =============================================================================
# DATA PIPELINE                                                       REQUIRED
# =============================================================================

# Auth token checked by jitsi_transcript_receiver (must match Jitsi stack).
# Leave blank to let the Jitsi installer generate and write it back here.
INGEST_TOKEN=

# Host port for the ingest receiver (default 9099; must not conflict with MinIO)
INGEST_PORT=9099

# Jitsi transcript text is parsed as UTC/GMT by default.
JITSI_TRANSCRIPT_TIMEZONE=UTC

# Serving API URLs used by stage1/stage2 forward workers (internal Docker names)
STAGE1_FORWARD_URL=http://serving-api:8000/segment
STAGE2_FORWARD_URL=http://serving-api:8000/summarize

# Shared data/setup + worker settings.
OBJECT_BUCKET=objstore-proj07
BLOCK_ROOT=/mnt/block
AMI_OBJECT_PREFIX=ami_public_manual_1.6.2

JITSI_BUILD_STAGE1_AFTER_INGEST=false
DB_TASK_POLL_INTERVAL_SECONDS=5
DB_TASK_FULL_SCAN_INTERVAL_SECONDS=300
DB_TASK_BATCH_SIZE=25
DB_TASK_FULL_SCAN_LIMIT=0
DB_TASK_STAGE1_BUILD_ENABLED=true
DB_TASK_STAGE1_FORWARD_ENABLED=true
DB_TASK_STAGE2_BUILD_ENABLED=true
DB_TASK_STAGE2_FORWARD_ENABLED=true
DB_TASK_USER_SUMMARY_ENABLED=true
DB_TASK_MEETING_VALIDITY_ENABLED=true
WORKFLOW_TASK_STALE_AFTER_SECONDS=600
WORKFLOW_TASK_HEARTBEAT_INTERVAL_SECONDS=15
WORKFLOW_TASK_BACKOFF_BASE_SECONDS=15
WORKFLOW_TASK_BACKOFF_MAX_SECONDS=900

STAGE1_BUILD_MAX_ATTEMPTS=8
STAGE1_FORWARD_MAX_ATTEMPTS=8
STAGE2_BUILD_MAX_ATTEMPTS=8
STAGE2_FORWARD_MAX_ATTEMPTS=8
USER_SUMMARY_MATERIALIZE_MAX_ATTEMPTS=8

STAGE1_BUILD_WORKER_POLL_INTERVAL_SECONDS=5
STAGE1_FORWARD_WORKER_POLL_INTERVAL_SECONDS=5
STAGE2_BUILD_WORKER_POLL_INTERVAL_SECONDS=5
STAGE2_FORWARD_WORKER_POLL_INTERVAL_SECONDS=5
USER_SUMMARY_WORKER_POLL_INTERVAL_SECONDS=5

STAGE1_WINDOW_SIZE=7
STAGE1_TRANSITION_INDEX=3
STAGE1_MIN_UTTERANCE_CHARS=20
STAGE1_MAX_WORDS_PER_UTTERANCE=50
STAGE1_MIN_INFERENCE_UTTERANCES=2
STAGE1_SHORT_MEETING_MAX_UTTERANCES=6
STAGE1_UPLOAD_ARTIFACTS=true
STAGE1_OBJECT_PREFIX=production/inference_requests/stage1
STAGE1_ARTIFACT_VERSION=1
STAGE1_BUILD_TIMEOUT_SECONDS=300
STAGE1_FORWARD_PAYLOAD_FORMAT=requests_json
STAGE1_FORWARD_TIMEOUT_SECONDS=300
STAGE1_FORWARD_UPLOAD_ARTIFACTS=true
STAGE1_RESPONSE_PREFIX=production/inference_responses/stage1

STAGE2_BOUNDARY_THRESHOLD=0.40
STAGE2_OBJECT_PREFIX=production/inference_requests/stage2
STAGE2_UPLOAD_ARTIFACTS=true
STAGE2_FORWARD_PAYLOAD_FORMAT=segment_json
STAGE2_FORWARD_TIMEOUT_SECONDS=300
STAGE2_FORWARD_UPLOAD_ARTIFACTS=true
STAGE2_RESPONSE_PREFIX=production/inference_responses/stage2
STAGE2_MODEL_NAME=stage2-summarizer
STAGE2_MODEL_VERSION=
STAGE2_PROMPT_VERSION=
SEGMENTS_PREFIX=production/reconstructed_segments

USER_SUMMARY_OBJECT_PREFIX=production/summary_edits
USER_SUMMARY_UPLOAD_ARTIFACTS=true

RETRAINING_DATASET_WORKER_POLL_INTERVAL_SECONDS=300
RETRAINING_DATASET_VALID_MEETING_THRESHOLD=50
RETRAINING_DATASET_FEEDBACK_EVENT_THRESHOLD=500
RETRAINING_DATASET_ADVISORY_LOCK_KEY=700507
RETRAINING_DATASET_UPLOAD_ARTIFACTS=true
RETRAINING_DATASET_NAME=roberta_stage1
RETRAINING_DATASET_ROOT=/mnt/block/roberta_stage1
RETRAINING_LOCAL_TMP_ROOT=/mnt/block/staging/feedback_loop
RETRAINING_FEEDBACK_POOL_PREFIX=datasets/roberta_stage1_feedback_pool
RETRAINING_DATASET_OBJECT_PREFIX=datasets/roberta_stage1
RETRAINING_DATASET_WINDOW_SIZE=7
RETRAINING_DATASET_TRANSITION_INDEX=3
RETRAINING_DATASET_MIN_UTTERANCE_CHARS=20
RETRAINING_DATASET_MAX_WORDS_PER_UTTERANCE=50
RETRAINING_DATASET_QUALITY_PSI_THRESHOLD=0.2
RETRAINING_DATASET_QUALITY_MAX_DRIFT_SHARE=0.35
RETRAINING_DATASET_QUALITY_MIN_FEATURE_SAMPLES=25
RETRAINING_DATASET_QUALITY_NUMERIC_BIN_COUNT=10

PRODUCTION_DRIFT_MONITOR_POLL_INTERVAL_SECONDS=900
PRODUCTION_DRIFT_MONITOR_LOOKBACK_HOURS=24
PRODUCTION_DRIFT_MONITOR_MIN_VALID_MEETINGS=5
PRODUCTION_DRIFT_MONITOR_DATASET_NAME=roberta_stage1
PRODUCTION_DRIFT_MONITOR_DATASET_ROOT=/mnt/block/roberta_stage1
PRODUCTION_DRIFT_MONITOR_WINDOW_SIZE=7
PRODUCTION_DRIFT_MONITOR_TRANSITION_INDEX=3
PRODUCTION_DRIFT_MONITOR_MIN_UTTERANCE_CHARS=20
PRODUCTION_DRIFT_MONITOR_MAX_WORDS_PER_UTTERANCE=50
PRODUCTION_DRIFT_MONITOR_PSI_THRESHOLD=0.2
PRODUCTION_DRIFT_MONITOR_MAX_DRIFT_SHARE=0.35
PRODUCTION_DRIFT_MONITOR_MIN_FEATURE_SAMPLES=25
PRODUCTION_DRIFT_MONITOR_NUMERIC_BIN_COUNT=10

BOOTSTRAP_SYNTHETIC_STAGE1_ENABLED=true
BOOTSTRAP_SYNTHETIC_STAGE1_VERSION=1
BOOTSTRAP_SYNTHETIC_STAGE1_MEETING_COUNT=3
BOOTSTRAP_SYNTHETIC_STAGE1_SEED=42
BOOTSTRAP_AMI_DB_ENABLED=true
BOOTSTRAP_DATASET_LINEAGE_ENABLED=true
BOOTSTRAP_STAGE1_BASELINE_ENABLED=true
SETUP_CONTINUE_ON_ERROR=true

# Manual-only traffic generator; this service only starts with the emulated-traffic profile.
MEETING_SOURCE_MODE=mixed
MEETING_COUNT=0
DELAY_SECONDS=15
IDENTITY_SOURCE=emulate_production
MEETING_NAME_PREFIX=synthetic
REQUEST_TIMEOUT_SECONDS=120
SEED=42

# =============================================================================
# PORTS  (change only if defaults conflict with other services)
# =============================================================================

JITSI_PORT=8443
JVB_PORT=10000
ADMINER_PORT=5050
HTTP_PORT=8088
HTTPS_PORT=8443
ENABLE_HTTP_REDIRECT=0

# =============================================================================
# RETRAINING
# =============================================================================

# Feedback events before retrain triggers. 5 for demo; 500 for production.
RETRAIN_THRESHOLD=5

# =============================================================================
# MONITORING
# =============================================================================

GRAFANA_PASSWORD=replace_with_password

# =============================================================================
# JITSI STACK  (only needed if running: DEPLOY_JITSI=true bash setup.sh)
# =============================================================================

# Public HTTPS URL — setup.sh fills this from FLOATING_IP and JITSI_PORT.
PUBLIC_URL=https://replace_with_chameleon_floating_ip:8443
JVB_ADVERTISE_IPS=replace_with_chameleon_floating_ip
TZ=UTC
JITSI_IMAGE_VERSION=stable-10741
DEPLOYMENT_IMAGE_TAG=vm

# Jitsi auth defaults for the meeting portal flow.
ENABLE_AUTH=1
ENABLE_GUESTS=1
AUTH_TYPE=jwt
JWT_APP_ID=meeting_portal_app
JWT_ACCEPTED_ISSUERS=meeting_portal_app
JWT_ACCEPTED_AUDIENCES=jitsi
JWT_ALLOW_EMPTY=0
TOKEN_AUTH_URL=/?auth=login
JICOFO_ENABLE_AUTH=0
WAIT_FOR_HOST_DISABLE_AUTO_OWNERS=1

# Explicit XMPP wiring for Jigasi/transcriber containers.
XMPP_DOMAIN=meet.jitsi
XMPP_SERVER=prosody
XMPP_BOSH_URL_BASE=http://prosody:5280
XMPP_AUTH_DOMAIN=auth.meet.jitsi
XMPP_GUEST_DOMAIN=guest.meet.jitsi
XMPP_MUC_DOMAIN=muc.meet.jitsi
XMPP_INTERNAL_MUC_DOMAIN=internal-muc.meet.jitsi
XMPP_HIDDEN_DOMAIN=hidden.meet.jitsi

# PostgreSQL DSN for the meeting-portal (uses FLOATING_IP — separate network)
MEETING_PORTAL_DATABASE_URL=postgresql://proj07_user:replace_with_strong_password@replace_with_chameleon_floating_ip:5432/proj07_sql_db

# Where transcript-uploader POSTs Jitsi transcripts (must match INGEST_PORT)
JITSI_TRANSCRIPT_INGEST_URL=http://replace_with_chameleon_floating_ip:9099/ingest/jitsi-transcript

# Leave blank — install-jitsi-vm.sh auto-generates these and writes them back here.
JWT_APP_SECRET=
MEETING_PORTAL_SESSION_SECRET=
JITSI_HOST_EXTERNAL_KEY=
JICOFO_AUTH_PASSWORD=
JVB_AUTH_PASSWORD=
JIGASI_XMPP_PASSWORD=
JIBRI_RECORDER_PASSWORD=
JIBRI_XMPP_PASSWORD=
JIGASI_TRANSCRIBER_PASSWORD=

MEETING_PORTAL_HTTPS_ONLY=true
MEETING_PORTAL_TOKEN_TTL_SECONDS=3600
MEETING_PORTAL_RCLONE_REMOTE=chi_tacc
MEETING_PORTAL_RCLONE_BUCKET=objstore-proj07
MEETING_PORTAL_RCLONE_TIMEOUT_SECONDS=10
MEETING_PORTAL_STAGE1_RCLONE_FALLBACK_ENABLED=true

ENABLE_TRANSCRIPTIONS=1
ENABLE_P2P=0
JIGASI_TRANSCRIBER_ENABLE_SAVING=true
JIGASI_TRANSCRIBER_RECORD_AUDIO=true
JIGASI_TRANSCRIBER_FILTER_SILENCE=0
JIGASI_TRANSCRIBER_CUSTOM_SERVICE=org.jitsi.jigasi.transcription.VoskTranscriptionService
JIGASI_TRANSCRIBER_VOSK_URL=ws://vosk:2700
VOSK_MODEL_URL=https://alphacephei.com/vosk/models/vosk-model-en-us-0.22-lgraph.zip

# SIP credentials for Jigasi (replace if using real PSTN/SIP provider)
JIGASI_DISABLE_SIP=1
JIGASI_SIP_URI=test@sip2sip.info
JIGASI_SIP_PASSWORD=passw0rd
JIGASI_SIP_SERVER=sip2sip.info
JIGASI_SIP_PORT=5060
JIGASI_SIP_TRANSPORT=UDP

ENABLE_LETSENCRYPT=0
LETSENCRYPT_DOMAIN=
LETSENCRYPT_EMAIL=
