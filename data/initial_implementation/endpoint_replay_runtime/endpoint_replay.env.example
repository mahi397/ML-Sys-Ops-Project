DATABASE_URL=postgresql://proj07_user:proj07@127.0.0.1:5432/proj07_sql_db
RCLONE_REMOTE=rclone_s3
BUCKET=objstore-proj07

ONLINE_STAGE1_ROOT=/mnt/block/user-behaviour/online_inference/stage1
STAGE1_RESPONSE_ROOT=/mnt/block/user-behaviour/inference_responses/stage1
ONLINE_STAGE2_ROOT=/mnt/block/user-behaviour/online_inference/stage2
STAGE2_RESPONSE_ROOT=/mnt/block/user-behaviour/inference_responses/stage2
SEGMENTS_ROOT=/mnt/block/user-behaviour/reconstructed_segments
RECAP_ROOT=/mnt/block/user-behaviour/recaps/generated
LOG_ROOT=/mnt/block/user-behaviour/logs/endpoint_replay

INPUT_MODE=synthetic
STAGE1_MODE=mock
STAGE2_MODE=mock
VERSION=1
MODEL_VERSION=flowise-stage2-v1
SYNTHETIC_MEETING_COUNT=3
SYNTHETIC_SEED=42

# Optional only when using http / flowise modes
STAGE1_URL=
STAGE2_URL=
FLOWISE_BASE_URL=
FLOWISE_FLOW_ID=
FLOWISE_API_KEY=

PYTHON_BIN=python3
