# Compatibility mirror only.
# Canonical shared config template lives at data/.env.example.
# Edit data/.env and let setup.sh point proj07-runtime/.env at it.

POSTGRES_DB=proj07_sql_db
POSTGRES_USER=proj07_user
POSTGRES_PASSWORD=proj07
POSTGRES_PORT=5432
POSTGRES_DATA_DIR=/mnt/block/postgres-data
ADMINER_PORT=5050

INGEST_TOKEN=
RCLONE_REMOTE=rclone_s3
BUCKET=objstore-proj07

JITSI_BUILD_STAGE1_AFTER_INGEST=false
JITSI_RAW_OBJECT_PREFIX=production/jitsi/raw_transcripts
JITSI_PARSED_OBJECT_PREFIX=production/jitsi/parsed_transcripts

DB_TASK_POLL_INTERVAL_SECONDS=5
DB_TASK_FULL_SCAN_INTERVAL_SECONDS=300
DB_TASK_BATCH_SIZE=25
DB_TASK_FULL_SCAN_LIMIT=0
DB_TASK_STAGE1_BUILD_ENABLED=true
DB_TASK_STAGE1_FORWARD_ENABLED=true
DB_TASK_STAGE2_BUILD_ENABLED=true
DB_TASK_STAGE2_FORWARD_ENABLED=true
DB_TASK_USER_SUMMARY_ENABLED=true
DB_TASK_MEETING_VALIDITY_ENABLED=true
WORKFLOW_TASK_STALE_AFTER_SECONDS=600
WORKFLOW_TASK_HEARTBEAT_INTERVAL_SECONDS=15
WORKFLOW_TASK_BACKOFF_BASE_SECONDS=15
WORKFLOW_TASK_BACKOFF_MAX_SECONDS=900

STAGE1_BUILD_MAX_ATTEMPTS=8
STAGE1_FORWARD_MAX_ATTEMPTS=8
STAGE2_BUILD_MAX_ATTEMPTS=8
STAGE2_FORWARD_MAX_ATTEMPTS=8
USER_SUMMARY_MATERIALIZE_MAX_ATTEMPTS=8

STAGE1_BUILD_WORKER_POLL_INTERVAL_SECONDS=5
STAGE1_FORWARD_WORKER_POLL_INTERVAL_SECONDS=5
STAGE2_BUILD_WORKER_POLL_INTERVAL_SECONDS=5
STAGE2_FORWARD_WORKER_POLL_INTERVAL_SECONDS=5
USER_SUMMARY_WORKER_POLL_INTERVAL_SECONDS=5

STAGE1_WINDOW_SIZE=7
STAGE1_TRANSITION_INDEX=3
STAGE1_MIN_UTTERANCE_CHARS=20
STAGE1_MAX_WORDS_PER_UTTERANCE=50
STAGE1_MIN_INFERENCE_UTTERANCES=2
STAGE1_SHORT_MEETING_MAX_UTTERANCES=6
STAGE1_UPLOAD_ARTIFACTS=true
STAGE1_OBJECT_PREFIX=production/inference_requests/stage1
STAGE1_ARTIFACT_VERSION=1
STAGE1_BUILD_TIMEOUT_SECONDS=300

STAGE1_FORWARD_URL=http://192.5.87.115:8000/segment
STAGE1_FORWARD_PAYLOAD_FORMAT=requests_json
STAGE1_FORWARD_TIMEOUT_SECONDS=300
STAGE1_RESPONSE_PREFIX=production/inference_responses/stage1
STAGE1_FORWARD_UPLOAD_ARTIFACTS=true

STAGE2_BOUNDARY_THRESHOLD=0.4
STAGE2_OBJECT_PREFIX=production/inference_requests/stage2
STAGE2_UPLOAD_ARTIFACTS=true
STAGE2_FORWARD_URL=http://192.5.87.115:8000/summarize
STAGE2_FORWARD_PAYLOAD_FORMAT=segment_json
STAGE2_FORWARD_TIMEOUT_SECONDS=300
STAGE2_FORWARD_UPLOAD_ARTIFACTS=true
STAGE2_RESPONSE_PREFIX=production/inference_responses/stage2
STAGE2_MODEL_NAME=stage2-summarizer
STAGE2_MODEL_VERSION=
STAGE2_PROMPT_VERSION=
SEGMENTS_PREFIX=production/reconstructed_segments

USER_SUMMARY_OBJECT_PREFIX=production/summary_edits
USER_SUMMARY_UPLOAD_ARTIFACTS=true

RETRAINING_DATASET_WORKER_POLL_INTERVAL_SECONDS=300
RETRAINING_DATASET_VALID_MEETING_THRESHOLD=50
RETRAINING_DATASET_FEEDBACK_EVENT_THRESHOLD=500
RETRAINING_DATASET_ADVISORY_LOCK_KEY=700507
RETRAINING_DATASET_UPLOAD_ARTIFACTS=true
RETRAINING_DATASET_NAME=roberta_stage1
RETRAINING_DATASET_ROOT=/mnt/block/roberta_stage1
RETRAINING_LOCAL_TMP_ROOT=/mnt/block/staging/feedback_loop
RETRAINING_FEEDBACK_POOL_PREFIX=datasets/roberta_stage1_feedback_pool
RETRAINING_DATASET_OBJECT_PREFIX=datasets/roberta_stage1
RETRAINING_DATASET_WINDOW_SIZE=7
RETRAINING_DATASET_TRANSITION_INDEX=3
RETRAINING_DATASET_MIN_UTTERANCE_CHARS=20
RETRAINING_DATASET_MAX_WORDS_PER_UTTERANCE=50

BOOTSTRAP_SYNTHETIC_STAGE1_ENABLED=true
BOOTSTRAP_SYNTHETIC_STAGE1_VERSION=1
BOOTSTRAP_SYNTHETIC_STAGE1_MEETING_COUNT=3
BOOTSTRAP_SYNTHETIC_STAGE1_SEED=42
