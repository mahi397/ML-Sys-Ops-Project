# =============================================================================
# .jitsi.env.example — Jitsi-specific configuration
# Copy to .jitsi.env. Most values are auto-populated by setup.sh on first run.
# Generated secrets (JWT_APP_SECRET, MEETING_PORTAL_SESSION_SECRET, etc.) are
# written here by setup.sh so they survive container restarts.
# =============================================================================

# ─── Public endpoint (filled in by setup.sh from FLOATING_IP) ────────────────
PUBLIC_URL=https://YOUR_FLOATING_IP:8443
JVB_ADVERTISE_IPS=YOUR_FLOATING_IP
HTTP_PORT=8088
HTTPS_PORT=8443
ENABLE_HTTP_REDIRECT=1
TZ=UTC

# ─── Jitsi image version ──────────────────────────────────────────────────────
JITSI_IMAGE_VERSION=stable-10741
DEPLOYMENT_IMAGE_TAG=vm

# ─── Auth / JWT ──────────────────────────────────────────────────────────────
ENABLE_AUTH=1
ENABLE_GUESTS=1
AUTH_TYPE=jwt
JWT_APP_ID=meeting_portal_app
JWT_ACCEPTED_ISSUERS=meeting_portal_app
JWT_ACCEPTED_AUDIENCES=jitsi
JWT_ALLOW_EMPTY=0
TOKEN_AUTH_URL=/?auth=login
JICOFO_ENABLE_AUTH=0
WAIT_FOR_HOST_DISABLE_AUTO_OWNERS=1

# ─── XMPP wiring ─────────────────────────────────────────────────────────────
XMPP_DOMAIN=meet.jitsi
XMPP_SERVER=prosody
XMPP_BOSH_URL_BASE=http://prosody:5280
XMPP_AUTH_DOMAIN=auth.meet.jitsi
XMPP_GUEST_DOMAIN=guest.meet.jitsi
XMPP_MUC_DOMAIN=muc.meet.jitsi
XMPP_INTERNAL_MUC_DOMAIN=internal-muc.meet.jitsi
XMPP_HIDDEN_DOMAIN=hidden.meet.jitsi

# ─── Generated secrets (auto-filled by setup.sh) ─────────────────────────────
JWT_APP_SECRET=CHANGE_ME
MEETING_PORTAL_SESSION_SECRET=CHANGE_ME
INGEST_TOKEN=CHANGE_ME
JITSI_HOST_EXTERNAL_KEY=CHANGE_ME
JICOFO_AUTH_PASSWORD=CHANGE_ME
JVB_AUTH_PASSWORD=CHANGE_ME
JIGASI_XMPP_PASSWORD=CHANGE_ME
JIGASI_TRANSCRIBER_PASSWORD=CHANGE_ME
JIBRI_RECORDER_PASSWORD=CHANGE_ME
JIBRI_XMPP_PASSWORD=CHANGE_ME

# ─── Jigasi / SIP ────────────────────────────────────────────────────────────
JIGASI_DISABLE_SIP=1

# ─── Transcription / Vosk ────────────────────────────────────────────────────
ENABLE_TRANSCRIPTIONS=1
ENABLE_P2P=0
JIGASI_TRANSCRIBER_ENABLE_SAVING=true
JIGASI_TRANSCRIBER_RECORD_AUDIO=true
JIGASI_TRANSCRIBER_FILTER_SILENCE=0
JIGASI_TRANSCRIBER_CUSTOM_SERVICE=org.jitsi.jigasi.transcription.VoskTranscriptionService
JIGASI_TRANSCRIBER_VOSK_URL=ws://vosk:2700
VOSK_MODEL_URL=https://alphacephei.com/vosk/models/vosk-model-en-us-0.22-lgraph.zip
VOSK_MODEL_PATH=/mnt/block/jitsi/config/models/vosk-model-en-us-0.22-lgraph

# ─── Meeting portal (filled in by setup.sh) ───────────────────────────────────
MEETING_PORTAL_DATABASE_URL=postgresql://proj07_user:CHANGE_ME@YOUR_FLOATING_IP:5432/proj07_sql_db
MEETING_PORTAL_HTTPS_ONLY=true
MEETING_PORTAL_TOKEN_TTL_SECONDS=3600
MEETING_PORTAL_RCLONE_REMOTE=chi_tacc
MEETING_PORTAL_RCLONE_BUCKET=objstore-proj07
MEETING_PORTAL_RCLONE_TIMEOUT_SECONDS=10
MEETING_PORTAL_STAGE1_RCLONE_FALLBACK_ENABLED=true

# ─── Transcript uploader (filled in by setup.sh) ─────────────────────────────
JITSI_TRANSCRIPT_INGEST_URL=http://YOUR_FLOATING_IP:9099/ingest/jitsi-transcript
JITSI_TRANSCRIPT_POLL_SECONDS=5
JITSI_TRANSCRIPT_SETTLE_SECONDS=3
JITSI_TRANSCRIPT_UPLOAD_TIMEOUT=120

# ─── Let's Encrypt (optional) ────────────────────────────────────────────────
ENABLE_LETSENCRYPT=0
LETSENCRYPT_DOMAIN=
LETSENCRYPT_EMAIL=
