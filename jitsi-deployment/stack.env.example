# Public entrypoint.
# Leave PUBLIC_URL or JVB_ADVERTISE_IPS blank only if you want the installer
# to infer them from the VM's primary IPv4 address.
PUBLIC_URL=
JVB_ADVERTISE_IPS=
TZ=UTC
HTTP_PORT=8000
HTTPS_PORT=8443
ENABLE_HTTP_REDIRECT=1

# Optional: pin the upstream Jitsi image tag.
JITSI_IMAGE_VERSION=stable-10741

# Jitsi auth defaults for the meeting portal flow.
ENABLE_AUTH=1
ENABLE_GUESTS=1
AUTH_TYPE=jwt
JWT_APP_ID=meeting_portal_app
JWT_ACCEPTED_ISSUERS=meeting_portal_app
JWT_ACCEPTED_AUDIENCES=jitsi
JWT_ALLOW_EMPTY=0
TOKEN_AUTH_URL=/?auth=login
JICOFO_ENABLE_AUTH=0
WAIT_FOR_HOST_DISABLE_AUTO_OWNERS=1

# Explicit XMPP wiring for Jigasi/transcriber containers.
# Using the Docker service name avoids the flaky reconnect path against the
# generated alias.
XMPP_DOMAIN=meet.jitsi
XMPP_SERVER=prosody
XMPP_BOSH_URL_BASE=http://prosody:5280
XMPP_AUTH_DOMAIN=auth.meet.jitsi
XMPP_GUEST_DOMAIN=guest.meet.jitsi
XMPP_MUC_DOMAIN=muc.meet.jitsi
XMPP_INTERNAL_MUC_DOMAIN=internal-muc.meet.jitsi
XMPP_HIDDEN_DOMAIN=hidden.meet.jitsi

# Set this to 0 only if you want the SIP gateway itself.
# For transcription-only installs, leave it at 1.
JIGASI_DISABLE_SIP=1

# Basic Jigasi configuration options (needed only when SIP gateway support is enabled).
# Replace these defaults with your SIP provider details if you set JIGASI_DISABLE_SIP=0.
JIGASI_SIP_URI=test@sip2sip.info
JIGASI_SIP_PASSWORD=passw0rd
JIGASI_SIP_SERVER=sip2sip.info
JIGASI_SIP_PORT=5060
JIGASI_SIP_TRANSPORT=UDP

# Meeting portal settings.
# Required. Replace with your VM's reachable Postgres DSN.
MEETING_PORTAL_DATABASE_URL=

# Optional; generated if left blank.
MEETING_PORTAL_SESSION_SECRET=
JWT_APP_SECRET=

MEETING_PORTAL_HTTPS_ONLY=true
MEETING_PORTAL_TOKEN_TTL_SECONDS=3600
MEETING_PORTAL_RCLONE_REMOTE=rclone_s3
MEETING_PORTAL_RCLONE_BUCKET=objstore-proj07
MEETING_PORTAL_RCLONE_TIMEOUT_SECONDS=10
MEETING_PORTAL_STAGE1_RCLONE_FALLBACK_ENABLED=true

# Transcription defaults.
ENABLE_TRANSCRIPTIONS=1
ENABLE_P2P=0
JIGASI_TRANSCRIBER_ENABLE_SAVING=true
JIGASI_TRANSCRIBER_RECORD_AUDIO=true
JIGASI_TRANSCRIBER_FILTER_SILENCE=0
JIGASI_TRANSCRIBER_CUSTOM_SERVICE=org.jitsi.jigasi.transcription.VoskTranscriptionService
JIGASI_TRANSCRIBER_VOSK_URL=ws://vosk:2700

# Transcript uploader settings.
# Required. Replace with your VM ingest endpoint.
JITSI_TRANSCRIPT_INGEST_URL=

# Optional; generated if left blank.
INGEST_TOKEN="your_actual_token_here"

# Generate once per VM and keep stable across restarts.
# mkdir -p ~/.config/jitsi-transcript-sender
# uuidgen > ~/.config/jitsi-transcript-sender/host_id
# cat ~/.config/jitsi-transcript-sender/host_id
JITSI_HOST_EXTERNAL_KEY=

JITSI_TRANSCRIPT_POLL_SECONDS=5
JITSI_TRANSCRIPT_SETTLE_SECONDS=3
JITSI_TRANSCRIPT_UPLOAD_TIMEOUT=120

# Optional Let's Encrypt support.
ENABLE_LETSENCRYPT=0
LETSENCRYPT_DOMAIN=
LETSENCRYPT_EMAIL=

# Optional deployment-specific image tag and model download URL.
DEPLOYMENT_IMAGE_TAG=vm
VOSK_MODEL_URL=https://alphacephei.com/vosk/models/vosk-model-en-us-0.22-lgraph.zip
